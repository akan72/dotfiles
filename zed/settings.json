{
    "cursor_blink": false,
    "terminal": {
        "cursor_shape": "bar"
    },
    "cursor_shape": "bar",
    "ui_font_family": "Hack Nerd Font Mono",
    // "ui_font_family": "Berkeley Mono Trial",
    "buffer_font_weight": 400.0,
    "buffer_font_family": ".ZedMono",
    // "buffer_font_family": "Berkeley Mono Trial",
    "edit_predictions": {
        "disabled_globs": []
    },
    "agent_servers": {
        "claude": {
        }
    },
    "ssh_connections": [
        {
            "host": "github.com",
            "projects": []
        }
    ],
    // Disable ligatures
    "buffer_font_features": {
      "calt": false
    },
    "icon_theme": "Catppuccin Latte",
    "relative_line_numbers": "enabled",
    "current_line_highlight": "none",
    "gutter": {
        "line_numbers": true
    },
    "minimap": {
        "show": "auto"
    },
    "autosave": {
        "after_delay": {
            "milliseconds": 1000
        }
    },
    "vim_mode": true,
    "base_keymap": "VSCode",
    "ui_font_size": 14.0,
    "buffer_font_size": 15.0,
    "tab_size": 4,
    "theme": {
        "mode": "system",
        "light": "Gruvbox Light",
        "dark": "Gruvbox Dark Hard"
    },
    "format_on_save": "off",
    "tabs": {
        "file_icons": true,
        "git_status": true
    },
    "file_scan_exclusions": [
        // Scan python generated files
        "**/.ruff_cache",
        "__pycache__",
        ".venv",
        // default values below
        "**/.git",
        "**/.svn",
        "**/.hg",
        "**/CVS",
        "**/.DS_Store",
        "**/Thumbs.db",
        "**/.classpath",
        "**/.settings"
    ],
    // Language server settings
    "languages": {
        "Python": {
            "language_servers": [
            // Disable basedpyright and enable Ty, and otherwise
            // use the default configuration.
            "ty",
            "!basedpyright",
            "..."
            ]
        }
    }
}
